<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kob.backend.mapper.UserMapper">
    <select id="getRecord" resultType="com.kob.backend.pojo.Question">
        select * from record_of_question where user_id = #{userId}
    </select>

    <update id="updateRecord">
        update record_of_question
        set score = #{questionScore}
        where user_id = #{userId} and question_id = #{questionId}
    </update>
</mapper>